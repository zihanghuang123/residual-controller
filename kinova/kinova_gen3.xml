                  <geom class="visual" mesh="spherical_wrist_2_link"/>
                  <geom class="collision" mesh="spherical_wrist_2_link"/>
                  <body name="bracelet_link" pos="0 -0.10593 -0.00017505" quat="1 -1 0 0">
                    <inertial pos="0.000281 0.011402 -0.029798" quat="0.394358 0.596779 -0.577293 0.393789" mass="0.5"
                      diaginertia="0.000657336 0.000587019 0.000320645"/>
                    <joint name="joint_7"/>
                    <geom class="visual" mesh="bracelet_with_vision_link"/>
                    <geom class="collision" mesh="bracelet_with_vision_link"/>
                    <site name="pinch_site" pos="0 0 -0.061525"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="joint_1" joint="joint_1" ctrllimited="true" ctrlrange="-39 39"/>
    <motor name="joint_2" joint="joint_2" ctrllimited="true" ctrlrange="-39 39"/>
    <motor name="joint_3" joint="joint_3" ctrllimited="true" ctrlrange="-39 39"/>
    <motor name="joint_4" joint="joint_4" ctrllimited="true" ctrlrange="-39 39"/>
    <motor name="joint_5" joint="joint_5" ctrllimited="true" ctrlrange="-9 9"/>
    <motor name="joint_6" joint="joint_6" ctrllimited="true" ctrlrange="-9 9"/>
    <motor name="joint_7" joint="joint_7" ctrllimited="true" ctrlrange="-9 9"/>
  </actuator>
</mujoco>
