<mujoco model="six_pendulum">
  <option integrator="implicitfast" timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0" frictionloss="0"/>
    <geom rgba="0.7 0.7 0.7 1" contype="0" conaffinity="0"/>
  </default>

  <worldbody>
    <light name="top" pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" pos="0 0 -7" size="7 7 0.1" rgba="0.8 0.9 0.8 1"/>

    <body name="link1" pos="0 0 0">
      <joint name="hinge1" type="hinge" axis="0 1 0"/>
      <inertial pos="0 0 -1.0" mass="1.0" diaginertia="1e-9 1e-9 1e-9"/>
      <geom name="link1_geom" type="cylinder" fromto="0 0 0 0 0 -1.0" size="0.02"/>

      <body name="link2" pos="0 0 -1.0">
        <joint name="hinge2" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 -1.0" mass="1.0" diaginertia="1e-9 1e-9 1e-9"/>
        <geom name="link2_geom" type="cylinder" fromto="0 0 0 0 0 -1.0" size="0.02"/>

        <body name="link3" pos="0 0 -1.0">
          <joint name="hinge3" type="hinge" axis="0 1 0"/>
          <inertial pos="0 0 -1.0" mass="1.0" diaginertia="1e-9 1e-9 1e-9"/>
          <geom name="link3_geom" type="cylinder" fromto="0 0 0 0 0 -1.0" size="0.02"/>

          <body name="link4" pos="0 0 -1.0">
            <joint name="hinge4" type="hinge" axis="0 1 0"/>
            <inertial pos="0 0 -1.0" mass="1.0" diaginertia="1e-9 1e-9 1e-9"/>
            <geom name="link4_geom" type="cylinder" fromto="0 0 0 0 0 -1.0" size="0.02"/>

            <body name="link5" pos="0 0 -1.0">
              <joint name="hinge5" type="hinge" axis="0 1 0"/>
              <inertial pos="0 0 -1.0" mass="1.0" diaginertia="1e-9 1e-9 1e-9"/>
              <geom name="link5_geom" type="cylinder" fromto="0 0 0 0 0 -1.0" size="0.02"/>

              <body name="link6" pos="0 0 -1.0">
                <joint name="hinge6" type="hinge" axis="0 1 0"/>
                <inertial pos="0 0 -1.0" mass="1.0" diaginertia="1e-9 1e-9 1e-9"/>
                <geom name="link6_geom" type="cylinder" fromto="0 0 0 0 0 -1.0" size="0.02"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="hinge1" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="motor2" joint="hinge2" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="motor3" joint="hinge3" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="motor4" joint="hinge4" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="motor5" joint="hinge5" ctrllimited="true" ctrlrange="-200 200"/>
    <motor name="motor6" joint="hinge6" ctrllimited="true" ctrlrange="-200 200"/>
  </actuator>
</mujoco>
